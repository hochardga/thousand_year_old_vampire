# Local development should use `.env.local`.
# Set `NEXT_PUBLIC_SITE_URL` to the production Vercel URL only.
# Preview deployments can rely on Vercel's `NEXT_PUBLIC_VERCEL_URL`.
# `ENABLE_TEST_AUTH=1` is for preview/dev testing only and must stay disabled in production.
# When enabled, preview/dev test sign-in can provision `e2e@example.com` with the password `nightfall`.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
ENABLE_TEST_AUTH=0
# Product analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
